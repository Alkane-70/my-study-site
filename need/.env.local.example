# =============================================
# 环境变量示例文件
# 复制此文件并重命名为 .env.local，填入你的 Supabase 密钥
# =============================================

# 你的 Supabase 项目 URL（在 Supabase 项目 Settings -> API 里获取）
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url-here

# 你的 Supabase 匿名密钥（anon public key）
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here